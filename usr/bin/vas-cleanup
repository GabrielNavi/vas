#!/bin/bash
set -euo pipefail

CONFIG_FILE="/etc/vas/vas.conf"
CONFIG_DIR="/etc/vas/vas.conf.d"

TTL_DEFAULT=30
DB_PATH="/var/lib/vas/vas.db"
VERSION_FILE="/var/lib/vas/version"

# Parser seguro: no ejecuta código del fichero de configuración.
load_conf() {
    local file="$1"
    [ -f "$file" ] || return 0

    while IFS='=' read -r key val; do
        key="$(echo "$key" | xargs 2>/dev/null || true)"
        val="$(echo "$val" | xargs 2>/dev/null | sed 's/^"//; s/"$//' || true)"
        [ -z "$key" ] && continue

        case "$key" in
            CLIENT_TTL_DAYS) TTL_DEFAULT="$val" ;;
            DB_PATH)         DB_PATH="$val"     ;;
            VERSION_FILE)    VERSION_FILE="$val" ;;
        esac
    done < <(grep -v '^\s*#' "$file" | grep '=' || true)
}

load_conf "$CONFIG_FILE"

if [ -d "$CONFIG_DIR" ]; then
    for cfg in "$CONFIG_DIR"/*.conf; do
        [ -f "$cfg" ] || continue
        load_conf "$cfg"
    done
fi

# -----------------------------
# Detectar interfaz (zenity → dialog → CLI)
# -----------------------------
use_zenity=false
use_dialog=false

if command -v zenity >/dev/null 2>&1; then
    use_zenity=true
elif command -v dialog >/dev/null 2>&1; then
    use_dialog=true
fi

ask_input() {
    local prompt="$1" default="$2"
    if $use_zenity; then
        zenity --entry --title="VAS Cleanup" --text="$prompt" --entry-text="$default" || exit 1
    elif $use_dialog; then
        dialog --stdout --inputbox "$prompt" 10 60 "$default" || exit 1
    else
        read -rp "$prompt [$default]: " val
        echo "${val:-$default}"
    fi
}

ask_confirm() {
    local msg="$1"
    if $use_zenity; then
        zenity --question --title="VAS Cleanup" --text="$msg" || exit 1
    elif $use_dialog; then
        dialog --yesno "$msg" 10 60 || exit 1
    else
        read -rp "$msg (y/N): " ans
        [[ "$ans" == "y" || "$ans" == "Y" ]] || exit 1
    fi
}

show_info() {
    local msg="$1"
    if $use_zenity; then
        zenity --info --title="VAS Cleanup" --text="$msg"
    elif $use_dialog; then
        dialog --msgbox "$msg" 8 60
    else
        echo "$msg"
    fi
}

# -----------------------------
# Pedir días y validar
# -----------------------------
DAYS=$(ask_input \
    "Introduce el número de días para purgar clientes antiguos.\nValor por defecto: $TTL_DEFAULT días" \
    "$TTL_DEFAULT")

if ! [[ "$DAYS" =~ ^[0-9]+$ ]]; then
    show_info "Valor inválido: $DAYS (debe ser un número entero)"
    exit 1
fi

if (( DAYS < 1 || DAYS > 365 )); then
    show_info "Valor fuera de rango: $DAYS (debe estar entre 1 y 365 días)"
    exit 1
fi

CUTOFF_DATE=$(date -u -d "$DAYS days ago" "+%Y-%m-%d %H:%M:%S UTC" 2>/dev/null \
    || date -u -v-"${DAYS}"d "+%Y-%m-%d %H:%M:%S UTC" 2>/dev/null \
    || echo "hace $DAYS días")

ask_confirm "¿Seguro que deseas eliminar clientes no vistos después de $CUTOFF_DATE?\nEsta acción es irreversible."

# -----------------------------
# Ejecutar limpieza
# Usamos <<'PYEOF' (comilla simple) para evitar interpolación de shell.
# Las rutas se pasan como variables de entorno.
# -----------------------------
echo "[CLEANUP] Eliminando clientes no vistos en más de $DAYS días..." >&2

CLEANUP_DAYS="$DAYS" \
VAS_DB_PATH="$DB_PATH" \
VAS_VERSION_FILE="$VERSION_FILE" \
python3 <<'PYEOF'
import os
import datetime
import sqlite3

days         = int(os.environ["CLEANUP_DAYS"])
db_path      = os.environ["VAS_DB_PATH"]
version_file = os.environ["VAS_VERSION_FILE"]

cutoff     = datetime.datetime.utcnow() - datetime.timedelta(days=days)
cutoff_str = cutoff.strftime("%Y-%m-%d %H:%M:%S UTC")

print(f"[CLEANUP] Cutoff: {cutoff_str}", flush=True)

conn = sqlite3.connect(db_path)
cur  = conn.cursor()

cur.execute("SELECT COUNT(*) FROM clients")
total_before = cur.fetchone()[0]

cur.execute("DELETE FROM clients WHERE last_seen < ?", (cutoff,))
deleted = cur.rowcount
conn.commit()
conn.close()

total_after = total_before - deleted
print(f"[CLEANUP] {deleted} cliente(s) eliminado(s), {total_after} restante(s).", flush=True)

if deleted > 0:
    version = datetime.datetime.utcnow().strftime("%Y%m%d%H%M%S")
    tmp = version_file + ".tmp"
    with open(tmp, "w") as f:
        f.write(version)
    os.replace(tmp, version_file)
    print(f"[CLEANUP] Versión actualizada a {version}.", flush=True)
    print("[CLEANUP] veyon-sync detectará el cambio en su próximo ciclo.", flush=True)
PYEOF

show_info "Limpieza completada.\nLos clientes activos se re-registrarán automáticamente.\nSi tienes vx-dga-l-veyon-sync instalado, actualizará Veyon en el próximo ciclo."
