#!/bin/bash
# vas-cleanup — Gestión manual del ciclo de vida de clientes VAS
#
# Permite ejecutar las tres transiciones de estado de forma interactiva:
#   1. Marcar inactivos  (active → inactive, no destructivo, sube versión)
#   2. Archivar          (inactive → archived, no destructivo)
#   3. Purgar            (archived → DELETE, destructivo e irreversible)
#
# Requiere permisos de escritura en la BD: ejecutar como root (sudo vas-cleanup).
#
# Journalctl: sudo journalctl -u vas -f  (para ver el efecto en VAS)

set -euo pipefail

CONFIG_FILE="/etc/vas/vas.conf"
CONFIG_DIR="/etc/vas/vas.conf.d"

DB_PATH="/var/lib/vas/vas.db"
VERSION_FILE="/var/lib/vas/version"
TTL_INACTIVE="30d"
TTL_ARCHIVE="90d"
TTL_PURGE="365d"

# ---------------------------------------------------------------------------
# Carga de configuración (parser seguro, sin source)
# ---------------------------------------------------------------------------
load_conf() {
    local file="$1"
    [ -f "$file" ] || return 0

    while IFS='=' read -r key val; do
        key="$(echo "$key" | xargs 2>/dev/null || true)"
        val="$(echo "$val" | xargs 2>/dev/null | sed 's/^"//; s/"$//' || true)"
        [ -z "$key" ] && continue

        case "$key" in
            DB_PATH)      DB_PATH="$val"      ;;
            VERSION_FILE) VERSION_FILE="$val"  ;;
            TTL_INACTIVE) TTL_INACTIVE="$val"  ;;
            TTL_ARCHIVE)  TTL_ARCHIVE="$val"   ;;
            TTL_PURGE)    TTL_PURGE="$val"     ;;
        esac
    done < <(grep -v '^\s*#' "$file" | grep '=' || true)
}

load_conf "$CONFIG_FILE"

if [ -d "$CONFIG_DIR" ]; then
    for cfg in "$CONFIG_DIR"/*.conf; do
        [ -f "$cfg" ] || continue
        load_conf "$cfg"
    done
fi

# ---------------------------------------------------------------------------
# Parser de duraciones
# ---------------------------------------------------------------------------
parse_duration_secs() {
    local val="$1"
    if [[ "$val" =~ ^([0-9]+)([sSmMhHdD])$ ]]; then
        local num="${BASH_REMATCH[1]}"
        local unit="${BASH_REMATCH[2],,}"   # lowercase
        case "$unit" in
            s) echo "$num" ;;
            m) echo $(( num * 60 )) ;;
            h) echo $(( num * 3600 )) ;;
            d) echo $(( num * 86400 )) ;;
        esac
    elif [[ "$val" =~ ^[0-9]+$ ]]; then
        echo "[WARN] Duración sin unidad: '$val'. Asumiendo días." >&2
        echo $(( val * 86400 ))
    else
        echo "[ERROR] Duración inválida: '$val'. Formato: 30d, 12h, 90m, 60s." >&2
        return 1
    fi
}

# ---------------------------------------------------------------------------
# Interfaz (zenity → dialog → CLI)
# ---------------------------------------------------------------------------
use_zenity=false
use_dialog=false

command -v zenity >/dev/null 2>&1 && use_zenity=true
$use_zenity || { command -v dialog >/dev/null 2>&1 && use_dialog=true; }

ask_input() {
    local prompt="$1" default="$2"
    if $use_zenity; then
        zenity --entry --title="VAS Cleanup" --text="$prompt" --entry-text="$default" || exit 1
    elif $use_dialog; then
        dialog --stdout --inputbox "$prompt" 10 60 "$default" || exit 1
    else
        read -rp "$prompt [$default]: " val
        echo "${val:-$default}"
    fi
}

ask_confirm() {
    local msg="$1"
    if $use_zenity; then
        zenity --question --title="VAS Cleanup" --text="$msg" || exit 1
    elif $use_dialog; then
        dialog --yesno "$msg" 10 60 || exit 1
    else
        read -rp "$msg (y/N): " ans
        [[ "$ans" == "y" || "$ans" == "Y" ]] || exit 1
    fi
}

show_info() {
    local msg="$1"
    if $use_zenity; then
        zenity --info --title="VAS Cleanup" --text="$msg"
    elif $use_dialog; then
        dialog --msgbox "$msg" 10 60
    else
        echo "$msg"
    fi
}

ask_duration() {
    local prompt="$1" default="$2"

    # Separar número y unidad del default (p.ej. "30d" → num=30 unit=d)
    local default_num default_unit
    if [[ "$default" =~ ^([0-9]+)([smhd])$ ]]; then
        default_num="${BASH_REMATCH[1]}"
        default_unit="${BASH_REMATCH[2]}"
    else
        default_num="${default//[^0-9]/}"
        default_unit="d"
    fi

    local s_on=off m_on=off h_on=off d_on=off
    case "$default_unit" in s) s_on=on;; m) m_on=on;; h) h_on=on;; d) d_on=on;; esac

    if $use_zenity; then
        local num unit
        num=$(zenity --entry --title="VAS Cleanup" \
            --text="$prompt — número:" \
            --entry-text="$default_num") || exit 1
        unit=$(zenity --list --title="VAS Cleanup" \
            --text="Unidad para '$prompt':" \
            --column="Código" --column="Unidad" \
            "s" "Segundos" "m" "Minutos" "h" "Horas" "d" "Días") || exit 1
        echo "${num}${unit:-d}"
    elif $use_dialog; then
        local num unit
        num=$(dialog --stdout --inputbox "$prompt (número):" 8 60 "$default_num") || exit 1
        unit=$(dialog --stdout --radiolist "Unidad para '$prompt':" 12 50 4 \
            "s" "Segundos" "$s_on" \
            "m" "Minutos"  "$m_on" \
            "h" "Horas"    "$h_on" \
            "d" "Días"     "$d_on") || exit 1
        echo "${num}${unit:-d}"
    else
        local val
        read -rp "$prompt [$default]: " val
        val="${val:-$default}"
        if [[ "$val" =~ ^[0-9]+$ ]]; then
            echo "[WARN] Sin unidad en '$val', asumiendo días." >&2
            val="${val}d"
        fi
        echo "$val"
    fi
}

ask_menu() {
    if $use_zenity; then
        zenity --list --title="VAS Cleanup" \
            --column="Opción" --column="Descripción" \
            "1" "Marcar inactivos (active → inactive, sube versión)" \
            "2" "Archivar inactivos (inactive → archived, histórico)" \
            "3" "Purgar archivados (archived → DELETE, irreversible)" \
            "4" "Ciclo completo (1+2+3 en secuencia)" \
            || exit 1
    elif $use_dialog; then
        dialog --stdout --menu "VAS Cleanup — elige operación:" 15 70 4 \
            "1" "Marcar inactivos (active → inactive)" \
            "2" "Archivar inactivos (inactive → archived)" \
            "3" "Purgar archivados (archived → DELETE)" \
            "4" "Ciclo completo (1+2+3)" \
            || exit 1
    else
        echo ""
        echo "VAS Cleanup — ciclo de vida de clientes"
        echo "  1) Marcar inactivos  (active → inactive, sube versión)"
        echo "  2) Archivar          (inactive → archived, histórico)"
        echo "  3) Purgar            (archived → DELETE, irreversible)"
        echo "  4) Ciclo completo    (1+2+3 en secuencia)"
        echo ""
        read -rp "Elige [1-4]: " choice
        echo "$choice"
    fi
}

# ---------------------------------------------------------------------------
# Verificaciones previas
# ---------------------------------------------------------------------------
if [ ! -f "$DB_PATH" ]; then
    show_info "Base de datos no encontrada: $DB_PATH\n¿Está VAS instalado y ha arrancado al menos una vez?"
    exit 1
fi

if [ ! -w "$DB_PATH" ]; then
    show_info "Sin permisos de escritura en $DB_PATH.\nEjecuta como root:\n\n  sudo vas-cleanup"
    exit 1
fi

# ---------------------------------------------------------------------------
# Menú y selección de TTLs
# ---------------------------------------------------------------------------
CHOICE="$(ask_menu)"

if ! [[ "$CHOICE" =~ ^[1-4]$ ]]; then
    show_info "Opción inválida: $CHOICE"
    exit 1
fi

# Pedir días para cada operación seleccionada
DO_INACTIVE=false
DO_ARCHIVE=false
DO_PURGE=false

case "$CHOICE" in
    1) DO_INACTIVE=true ;;
    2) DO_ARCHIVE=true  ;;
    3) DO_PURGE=true    ;;
    4) DO_INACTIVE=true; DO_ARCHIVE=true; DO_PURGE=true ;;
esac

if $DO_INACTIVE; then
    DUR_INACTIVE="$(ask_duration "Tiempo sin heartbeat para marcar como INACTIVO" "$TTL_INACTIVE")"
    [[ "$DUR_INACTIVE" =~ ^[0-9]+[smhd]?$ ]] || { show_info "Valor inválido: $DUR_INACTIVE"; exit 1; }
fi

if $DO_ARCHIVE; then
    DUR_ARCHIVE="$(ask_duration "Tiempo sin heartbeat para ARCHIVAR (inactive → archived)" "$TTL_ARCHIVE")"
    [[ "$DUR_ARCHIVE" =~ ^[0-9]+[smhd]?$ ]] || { show_info "Valor inválido: $DUR_ARCHIVE"; exit 1; }
fi

if $DO_PURGE; then
    DUR_PURGE="$(ask_duration "Tiempo sin heartbeat para BORRAR definitivamente (0d = desactivado)" "$TTL_PURGE")"
    [[ "$DUR_PURGE" =~ ^[0-9]+[smhd]?$ ]] || { show_info "Valor inválido: $DUR_PURGE"; exit 1; }
fi

# Confirmación final
SUMMARY=""
$DO_INACTIVE && SUMMARY+="• Marcar inactivos: sin heartbeat desde hace ${DUR_INACTIVE}\n"
$DO_ARCHIVE  && SUMMARY+="• Archivar: inactivos desde hace ${DUR_ARCHIVE}\n"
$DO_PURGE    && SUMMARY+="• Purgar: archivados desde hace ${DUR_PURGE} (IRREVERSIBLE)\n"

ask_confirm "Se ejecutarán las siguientes operaciones:\n\n${SUMMARY}\n¿Continuar?"

# ---------------------------------------------------------------------------
# Ejecutar operaciones en Python (sin importar módulos de VAS)
# ---------------------------------------------------------------------------
echo "[VAS-CLEANUP] Iniciando gestión de ciclo de vida..." >&2

[[ "$DO_INACTIVE" == "true" ]] && DO_INACTIVE_PY="True" || DO_INACTIVE_PY="False"
[[ "$DO_ARCHIVE"  == "true" ]] && DO_ARCHIVE_PY="True"  || DO_ARCHIVE_PY="False"
[[ "$DO_PURGE"    == "true" ]] && DO_PURGE_PY="True"    || DO_PURGE_PY="False"

SECS_INACTIVE=0; SECS_ARCHIVE=0; SECS_PURGE=0
$DO_INACTIVE && SECS_INACTIVE="$(parse_duration_secs "${DUR_INACTIVE:-0d}")"
$DO_ARCHIVE  && SECS_ARCHIVE="$(parse_duration_secs "${DUR_ARCHIVE:-0d}")"
$DO_PURGE    && SECS_PURGE="$(parse_duration_secs "${DUR_PURGE:-0d}")"

DO_INACTIVE_ENV="$DO_INACTIVE_PY" \
DO_ARCHIVE_ENV="$DO_ARCHIVE_PY" \
DO_PURGE_ENV="$DO_PURGE_PY" \
SECS_INACTIVE_ENV="$SECS_INACTIVE" \
SECS_ARCHIVE_ENV="$SECS_ARCHIVE" \
SECS_PURGE_ENV="$SECS_PURGE" \
DUR_INACTIVE_ENV="${DUR_INACTIVE:-0d}" \
DUR_ARCHIVE_ENV="${DUR_ARCHIVE:-0d}" \
DUR_PURGE_ENV="${DUR_PURGE:-0d}" \
VAS_DB_PATH="$DB_PATH" \
VAS_VERSION_FILE="$VERSION_FILE" \
python3 <<'PYEOF'
import os, datetime, sqlite3
from datetime import timezone

def utcnow():
    return datetime.datetime.now(timezone.utc).replace(tzinfo=None)

db_path      = os.environ["VAS_DB_PATH"]
version_file = os.environ["VAS_VERSION_FILE"]
do_inactive  = os.environ["DO_INACTIVE_ENV"] == "True"
do_archive   = os.environ["DO_ARCHIVE_ENV"]  == "True"
do_purge     = os.environ["DO_PURGE_ENV"]    == "True"
secs_i       = int(os.environ["SECS_INACTIVE_ENV"])
secs_a       = int(os.environ["SECS_ARCHIVE_ENV"])
secs_p       = int(os.environ["SECS_PURGE_ENV"])
dur_i        = os.environ["DUR_INACTIVE_ENV"]
dur_a        = os.environ["DUR_ARCHIVE_ENV"]
dur_p        = os.environ["DUR_PURGE_ENV"]

conn = sqlite3.connect(db_path)
cur  = conn.cursor()

version_bumped = False

def bump_version():
    global version_bumped
    now = utcnow()
    v = now.strftime("%Y%m%d%H%M%S") + f"{now.microsecond // 1000:03d}"
    tmp = version_file + ".tmp"
    with open(tmp, "w") as f:
        f.write(v)
    os.replace(tmp, version_file)
    version_bumped = True
    return v

# Paso 1: active → inactive
if do_inactive:
    cutoff = utcnow() - datetime.timedelta(seconds=secs_i)
    cur.execute(
        "UPDATE clients SET status='inactive' WHERE status='active' AND last_seen < ?",
        (cutoff,)
    )
    n = cur.rowcount
    conn.commit()
    if n > 0:
        v = bump_version()
        print(f"[VAS-CLEANUP] {n} cliente(s) → inactive. Versión publicada: {v}", flush=True)
    else:
        print(f"[VAS-CLEANUP] Ningún cliente activo supera {dur_i} de inactividad.", flush=True)

# Paso 2: inactive → archived
if do_archive:
    cutoff = utcnow() - datetime.timedelta(seconds=secs_a)
    cur.execute(
        "UPDATE clients SET status='archived' WHERE status='inactive' AND last_seen < ?",
        (cutoff,)
    )
    n = cur.rowcount
    conn.commit()
    if n > 0:
        print(f"[VAS-CLEANUP] {n} cliente(s) → archived.", flush=True)
    else:
        print(f"[VAS-CLEANUP] Ningún cliente inactivo supera {dur_a}.", flush=True)

# Paso 3: archived → DELETE
if do_purge:
    if secs_p == 0:
        print("[VAS-CLEANUP] Purga desactivada (0).", flush=True)
    else:
        cutoff = utcnow() - datetime.timedelta(seconds=secs_p)
        cur.execute(
            "DELETE FROM clients WHERE status='archived' AND last_seen < ?",
            (cutoff,)
        )
        n = cur.rowcount
        conn.commit()
        if n > 0:
            print(f"[VAS-CLEANUP] {n} cliente(s) eliminado(s) definitivamente.", flush=True)
        else:
            print(f"[VAS-CLEANUP] Ningún cliente archivado supera {dur_p}.", flush=True)

conn.close()

# Resumen final de la BD
conn2 = sqlite3.connect(db_path)
cur2  = conn2.cursor()
cur2.execute("SELECT status, COUNT(*) FROM clients GROUP BY status")
rows = cur2.fetchall()
conn2.close()
summary = ", ".join(f"{s}: {c}" for s, c in rows) or "BD vacía"
print(f"[VAS-CLEANUP] Estado BD: {summary}", flush=True)
if version_bumped:
    print("[VAS-CLEANUP] veyon-sync detectará el cambio en su próximo ciclo.", flush=True)
PYEOF

show_info "Operación completada.\nConsulta journalctl -u vas -f para ver el efecto en VAS.\nLos clientes activos se re-registrarán automáticamente."
