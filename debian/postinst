#!/bin/sh
set -e

case "$1" in
    configure)
        # Crear usuario de sistema si no existe
        if ! getent passwd vas > /dev/null 2>&1; then
            adduser --system --no-create-home --group vas || true
        fi

        # Crear directorios persistentes
        mkdir -p /var/lib/vas /var/log/vas /etc/vas/vas.conf.d /etc/vas/hooks.d
        chown -R vas:vas /var/lib/vas /var/log/vas

        # Inicializar fichero de versión
        if [ ! -f /var/lib/vas/version ]; then
            echo "0" > /var/lib/vas/version
            chown vas:vas /var/lib/vas/version
        fi

        # Instalación fresca: activar hook val-local (notificación push VAL-Aware)
        if [ -z "${2:-}" ]; then
            HOOK_SRC="/usr/share/vas/hooks.d.examples/val-local"
            HOOK_DST="/etc/vas/hooks.d/val-local"
            if [ -f "$HOOK_SRC" ] && [ ! -f "$HOOK_DST" ]; then
                cp "$HOOK_SRC" "$HOOK_DST"
                chmod +x "$HOOK_DST"
            fi
        fi
        ;;
esac

#DEBHELPER#
