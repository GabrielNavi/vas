#!/bin/sh
set -e

echo "[VAS] Ejecutando postinst..."

# Crear usuario de sistema si no existe
if ! getent passwd vas > /dev/null 2>&1; then
    adduser --system --no-create-home --group vas || true
fi

# Crear directorios persistentes con permisos correctos
mkdir -p /var/lib/vas
mkdir -p /var/log/vas
mkdir -p /etc/vas/vas.conf.d
mkdir -p /etc/vas/hooks.d

chown -R vas:vas /var/lib/vas
chown -R vas:vas /var/log/vas

# Crear archivo de versión si no existe
if [ ! -f /var/lib/vas/version ]; then
    echo "0" > /var/lib/vas/version
    chown vas:vas /var/lib/vas/version
fi

# Recargar systemd
systemctl daemon-reload || true

# Habilitar servicio
systemctl enable vas.service || true

# Arrancar en instalación fresca y reiniciar tras upgrade
if [ "$1" = "configure" ]; then
    if [ -n "${2:-}" ]; then
        systemctl restart vas.service || true
    else
        # Instalación fresca: activar hook val-local (notificación push a VAL-Aware)
        HOOK_SRC="/usr/share/vas/hooks.d.examples/val-local"
        HOOK_DST="/etc/vas/hooks.d/val-local"
        if [ -f "$HOOK_SRC" ] && [ ! -f "$HOOK_DST" ]; then
            cp "$HOOK_SRC" "$HOOK_DST"
            chmod +x "$HOOK_DST"
            echo "[VAS] Hook val-local instalado en $HOOK_DST"
        fi
        systemctl start vas.service || true
    fi
fi

echo "[VAS] Instalación completada."
